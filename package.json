{
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/example-app",
    "packages/mcp-server",
    "packages/cli",
    "packages/plural"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "mutate": "npm run mutate --workspaces --if-present",
    "precli": "npm run build --workspace=packages/cli",
    "cli": "node packages/cli/build/index.js"
  },
  "overrides": {
    "@stryker-mutator/core": "9.4.0",
    "@stryker-mutator/*": "9.4.0",
    "zod": "^4.0.0"
  }
}
