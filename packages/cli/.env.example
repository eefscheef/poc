# OpenAI Configuration (checked first)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Optional: Custom base URL for OpenAI-compatible endpoints
# OPENAI_BASE_URL=https://api.openai.com/v1

# Alternative: Anthropic Configuration (checked second)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Alternative: Google Gemini Configuration (checked third)
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_MODEL=gemini-2.0-flash-lite

# Testing: Set to true to run live API tests (costs money)
# RUN_LIVE_TESTS=true
